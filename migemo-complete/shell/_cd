#compdef cd pushd
#
# zsh completion adapter for migemo-complete.
#
# Install:
#   1. Copy (or symlink) this file into a directory on your $fpath, keeping
#      the filename "_cd", e.g.:
#        mkdir -p ~/.zsh/completions
#        cp _cd ~/.zsh/completions/_cd
#        fpath=(~/.zsh/completions $fpath)
#   2. Make sure the fpath line above comes *before*
#      `autoload -Uz compinit && compinit` in your .zshrc, and that
#      ~/.zsh/completions is early in $fpath so it is found ahead of zsh's
#      stock `_cd`.
#   3. Make sure the migemo-complete binary is on $PATH, or set
#      MIGEMO_COMPLETE_BIN to its absolute path.
#
# Falls back to zsh's normal directory completion (_files -/) if the binary
# is missing or returns no candidates, so a stale install never breaks `cd`.

_migemo_cd() {
    local bin="${MIGEMO_COMPLETE_BIN:-migemo-complete}"
    if (( ! $+commands[$bin] )) && [[ ! -x "$bin" ]]; then
        _files -/
        return
    fi

    local cur="${words[CURRENT]}"
    local -a candidates
    candidates=("${(@f)$("$bin" --cwd "$PWD" --kind dir -- "$cur" 2>/dev/null)}")

    if (( ${#candidates} == 0 )); then
        _files -/
        return
    fi

    # -U: accept candidates as-is, skipping zsh's own prefix-anchored
    #     filtering (a migemo hit like "アプリ" doesn't literally start
    #     with the typed romaji "ap", so the default filter would drop it).
    # -S '': no auto-appended suffix; candidates already carry their own
    #     trailing "/" for directories (see format_candidate in lib.rs).
    compadd -U -Q -S '' -a candidates
}

_migemo_cd "$@"
